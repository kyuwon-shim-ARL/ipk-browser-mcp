  "inference_rules": {
    "nights_days": {
      "description": "Infer nights/days from date range",
      "rule": "nights = (end_date - start_date).days; days = nights + 1"
    },
    "daily_expense": {
      "description": "Infer daily expense from nights",
      "rule": "if nights == 0: 20000 (66% of corpus); if nights >= 1: 30000 (31%)",
      "values": {
        "day_trip": 20000,
        "overnight": 30000
      },
      "confidence": 0.97
    },
    "budget_account_from_bc": {
      "description": "Budget Control No -> Budget Account Code (deterministic lookup)",
      "rule": "100% deterministic: each BC# maps to exactly one budget_account",
      "confidence": 1.0,
      "note": "BC# is required user input, not inferrable"
    },
    "account_code_from_budget_type": {
      "description": "Budget type determines account code",
      "rule": "R&D -> 410201 (Domestic Business Travel); General -> 420312 (Business Travel - Domestic)",
      "values": {
        "R&D": "410201",
        "General": "420312"
      },
      "confidence": 1.0
    },
    "corp_card": {
      "description": "Per-traveler soft default from profile",
      "rule": "lookup traveler_profiles.json -> corp_card.default",
      "confidence_range": "60-100% depending on traveler",
      "note": "shared lab resource, always confirm with user"
    },
    "transport_from_destination": {
      "description": "Transport mode partially inferrable from destination region",
      "rules": [
        {
          "condition": "Seoul day-trip",
          "transport": "Other Public Transportation",
          "confidence": 0.85
        },
        {
          "condition": "Gyeonggi-do",
          "transport": "variable (public 33% vs vehicle 67%)",
          "confidence": 0.67
        },
        {
          "condition": "outside metro (Gangwon, Busan, etc)",
          "transport": "Own Vehicle",
          "confidence": 0.8
        }
      ]
    },
    "business_travel_type": {
      "description": "Infer from purpose keywords",
      "rules": [
        {
          "keywords": [
            "conference",
            "symposium",
            "seminar",
            "workshop",
            "meeting",
            "forum"
          ],
          "value": "Participation in the conference/seminar",
          "code": "2"
        },
        {
          "keywords": [
            "sampling",
            "collection",
            "visit",
            "survey"
          ],
          "value": "Simple visit to vendor & etc",
          "code": "5"
        },
        {
          "keywords": [
            "training",
            "교육"
          ],
          "value": "Training",
          "code": "3"
        },
        {
          "keywords": [
            "presentation",
            "poster",
            "paper"
          ],
          "value": "Post or Paper presentation",
          "code": "4"
        }
      ],
      "distribution": {
        "conference/seminar": 0.47,
        "vendor visit": 0.44,
        "training": 0.04,
        "presentation": 0.02
      }
    }
  },
