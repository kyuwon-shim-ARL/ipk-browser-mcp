  "own_vehicle_rules": {
    "description": "When transport_mode is 'Own Vehicle - Gasoline' or 'Own Vehicle - Diesel'",
    "cost_formula": "oil_price_per_liter × distance_km / fuel_efficiency(10km/L)",
    "observed_oil_prices": [1584, 1668, 1906],
    "oil_price_unit": "KRW/L",
    "distance_source": "Naver Maps (map.naver.com) driving route from IPK (판교) to destination",
    "required_attachments": {
