# IPK Groupware Credentials
# Copy this file to .env and fill in your credentials
# NEVER commit .env to git!

# 필수
IPK_USERNAME=your.username
IPK_PASSWORD=your_password

# 선택 (미설정시 username에서 추출)
IPK_USER_NAME=Your Name
IPK_USER_DEPT=Your Department

# 휴가 기본값 (선택)
IPK_SUBSTITUTE_NAME=
IPK_SUBSTITUTE_CONTACT=
IPK_EMERGENCY_ADDRESS=Seoul
IPK_EMERGENCY_TELEPHONE=
