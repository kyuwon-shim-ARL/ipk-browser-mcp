{
  "name": "ipk-browser-mcp",
  "version": "0.1.0",
  "description": "IPK Groupware browser automation MCP server for Claude Code",
  "type": "module",
  "main": "dist/ipk-browser-mcp.mjs",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "node --watch dist/ipk-browser-mcp.mjs",
    "start": "node dist/ipk-browser-mcp.mjs",
    "typecheck": "tsc --noEmit",
    "lint:security": "grep -rn 'evaluate(`' src/ && echo 'FAIL: template literal in evaluate' && exit 1 || echo 'PASS: no template literals in evaluate'"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "playwright": "^1.52.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/",
    ".claude-plugin/",
    ".mcp.json"
  ],
  "license": "MIT",
  "private": true
}
