  "travel": {
    "_form_code": "AppFrm-076",
    "_description": "출장보고서",
    "_raw_context_hint": "최소 입력 예시: 학회 URL, 포럼 프로그램 PDF, 받아적은 메모, 이메일 초대장 등",
    "_raw_context_what_ai_needs": "어디(장소), 언제(날짜), 왜(목적/학회명), 무엇을(프로그램/세션). 이 4가지만 있으면 나머지 모두 추론 가능.",
    "_inference_example": "사용자: '2026 KMB Winter Symposium, Shenzhen, 1/6~1/10' → AI가 제목, 목적, 기관, 토의안건, 의제, 결과예상, 결론 모두 추론",

    "strict_fields": {
      "start_date": {
        "html_name": "start_day",
        "description": "출장 시작일",
        "format": "YYYY-MM-DD",
        "why_strict": "날짜 오류 시 출장비/일비 정산 불가.",
        "inference_allowed": true,
        "inference_note": "'1/6' → 2026-01-06. 학회 일정에서 추출 가능."
      },
      "end_date": {
        "html_name": "end_day",
        "description": "출장 종료일",
        "format": "YYYY-MM-DD",
        "why_strict": "날짜 오류 시 출장비/일비 정산 불가.",
        "validation": ["must_be_valid_date", "must_be_gte_start_date"],
        "inference_allowed": true
      },
      "destination": {
        "html_name": "report_dest",
        "description": "출장지",
        "why_strict": ".validate 필드. 빈값이면 제출 차단.",
        "inference_allowed": true,
        "inference_note": "학회 장소에서 추출. 'Shenzhen, China' 등."
      }
    },

    "inferable_fields": {
      "title": {
        "html_name": "subject",
        "description": "출장 제목",
        "inference_context": "학회명 + 출장 유형. 예: '2026 KMB Winter Symposium 참석'"
      },
      "purpose": {
        "html_name": "purpose_field",
        "description": "출장 목적",
        "inference_context": "학회 참석, 공동연구, 장비 점검 등. raw context에서 추론."
      },
      "organization": {
        "html_name": "org_field",
        "description": "방문 기관/학회명",
        "inference_context": "학회명 또는 기관명. 'KMB', 'KAIST' 등."
      },
      "discuss_field": {
        "html_name": "discuss_field",
        "description": "토의 안건",
        "inference_context": "학회 세션, 발표 주제, 미팅 안건 등. 프로그램에서 추출 가능."
      },
      "agenda_field": {
        "html_name": "agenda_field",
        "description": "회의 의제",
        "inference_context": "구체적 세션명, 포스터 발표, 워크숍 등. 프로그램에서 추출."
      },
      "result_field": {
        "html_name": "result_field",
        "description": "출장 결과/성과 (사전: 기대성과, 사후: 실제성과)",
        "inference_context": "사전제출: 'Expected to learn about...', 사후제출: 실제 성과 기술."
      },
      "attendees": {
        "html_name": "person_field",
        "description": "참석자",
        "default": "본인 이름",
        "inference_context": "동행자 언급 있으면 추가."
      },
      "conclusion_field": {
        "html_name": "conclusion_field",
        "description": "결론/소감",
        "inference_context": "목적 + 기대효과 기반 자동 생성."
      },
      "other_field": {
        "html_name": "other_field",
        "description": "기타사항",
        "default": "N/A",
        "inference_context": "특이사항 없으면 N/A."
      }
    },

    "config_fields": {
      "report_name": { "html_name": "report_name", "source": "session userInfo.name" },
      "report_post": { "html_name": "report_post", "source": "IPK_USER_POSITION", "default": "Researcher" },
      "report_group": {
        "html_name": "report_group",
        "source": "IPK_USER_DEPT",
        "why_strict": ".validate 필드. 빈값이면 차단.",
        "must_not_be_empty": true,
        "behavior_if_unset": "block_submit_with_message",
        "unset_message": "IPK_USER_DEPT 환경변수를 설정하세요"
      },
      "report_leader": {
        "html_name": "report_leader",
        "source": "IPK_GROUP_LEADER",
        "why_strict": ".validate 필드. 빈값이면 차단.",
        "must_not_be_empty": true,
        "behavior_if_unset": "block_submit_with_message",
        "unset_message": "IPK_GROUP_LEADER 환경변수를 설정하세요"
      }
    },

    "auto_fields": {
      "schedule": "{시작일} ~ {종료일}",
      "report_date": "오늘 날짜"
    },

    "attachment_rules": { "required": false, "note": "권장 (학회 참석증 등), JS 강제 없음" }
  }
}
